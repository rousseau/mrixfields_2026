# sync_from_jeanzay.sh.env.example
# =============================================================================
# Copier ce fichier en .sync_env à la racine du projet et renseigner les valeurs.
# Ce fichier (.sync_env) est ignoré par git — ne jamais commiter .sync_env.
#
#   cp src/slurm/sync_from_jeanzay.sh.env.example .sync_env
#   # puis éditer .sync_env
#
# Après avoir renseigné ce fichier, configurer les clés SSH (connexion sans
# mot de passe) en lançant une seule fois :
#   bash src/slurm/setup_ssh_keys.sh
# =============================================================================

# ── Utilisé par : sync_from_jeanzay.sh ──────────────────────────────────────

# Chemin racine du projet sur Jean Zay (lustre fswork) — OBLIGATOIRE
# Exemple : /lustre/fswork/projects/rech/crp/<JEANZAY_USER>/MRIX/mrixfields_2026
REMOTE_BASE=

# Alias SSH défini dans ~/.ssh/config par setup_ssh_keys.sh (défaut: jeanzay)
# Modifier uniquement si vous avez choisi un alias différent.
# SSH_ALIAS=jeanzay

# ── Utilisé par : setup_ssh_keys.sh ─────────────────────────────────────────
# (Nécessaire uniquement pour la configuration initiale des clés SSH)

# Login Jean Zay (identifiant IDRIS)
JEANZAY_USER=

# Hôte Jean Zay
JEANZAY_HOST=jean-zay.idris.fr

# Proxy SSH (passerelle institution)
PROXY_USER=
PROXY_HOST=
