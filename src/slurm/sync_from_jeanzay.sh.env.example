# sync_from_jeanzay.sh.env.example
# Copier ce fichier en .sync_env à la racine du projet et renseigner les valeurs.
# Ce fichier est ignoré par git (.gitignore).
#
#   cp src/slurm/sync_from_jeanzay.sh.env.example .sync_env

# Identifiants Jean Zay
JEANZAY_USER=ulq73oz
JEANZAY_HOST=jean-zay.idris.fr

# Proxy SSH (passerelle Télécom Bretagne)
PROXY_USER=froussea
PROXY_HOST=ssh.telecom-bretagne.eu

# Chemin racine du projet sur Jean Zay (lustre fswork)
# Laisser vide pour utiliser la valeur par défaut :
# /lustre/fswork/projects/rech/crp/${JEANZAY_USER}/MRIX/mrixfields_2026
REMOTE_BASE=
